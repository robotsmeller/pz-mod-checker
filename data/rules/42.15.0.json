  "release_date": "2026-03-09",
  "changes": [
    {
      "id": "b42-15-translation-json",
      "type": "structure",
      "severity": "info",
      "confidence": "certain",
      "since": "42.15.0",
      "description": "42.15+ uses JSON translation files — .txt translations should be migrated to JSON",
      "path": "42/media/lua/shared/Translate/",
      "check": "dir_exists",
      "condition": {"has_files_in_dir": "media/lua/shared/Translate", "file_glob": "*.txt"}
    },
    {
