      "new_name": "Apocalypse/Outbreak/Extinction/Rising",
      "scan": "*.lua",
      "context": "Game modes renamed in 42.15",
      "group": "gamemode-renames"
    },
    {
      "id": "b42-15-gamemode-survivor",
      "type": "api_rename",
      "severity": "info",
      "confidence": "certain",
      "since": "42.15.0",
      "description": "Survivor game mode removed — replaced with new mode names",
      "old_pattern": "\\\"Survivor\\\"",
      "new_name": "Apocalypse/Outbreak/Extinction/Rising",
      "scan": "*.lua",
      "context": "Game modes renamed in 42.15",
      "group": "gamemode-renames"
    }
  ]
