{
  "version": "42.15.0",
  "summary": "Translation format change to JSON, mod structure relaxed, game mode renames",
  "source": "https://pzwiki.net/wiki/Build_42.15.0",
  "release_date": "2026-03-09",
  "changes": [
    {
      "id": "b42-15-translation-json",
      "type": "structure",
      "severity": "info",
      "since": "42.15.0",
      "description": "42.15+ uses JSON translation files — check that translations are in .json format",
      "path": "42/media/lua/shared/Translate/",
      "check": "dir_exists"
    },
    {
      "id": "b42-15-gamemode-builder",
      "type": "api_rename",
      "severity": "info",
      "since": "42.15.0",
      "description": "Builder game mode removed — replaced with new mode names",
      "old_pattern": "\\\"Builder\\",
      "new_name": "Apocalypse/Outbreak/Extinction/Rising",
      "scan": "*.lua",
      "context": "Game modes renamed in 42.15"
    },
    {
      "id": "b42-15-gamemode-survivor",
      "type": "api_rename",
      "severity": "info",
      "since": "42.15.0",
      "description": "Survivor game mode removed — replaced with new mode names",
      "old_pattern": "\\\"Survivor\\",
      "new_name": "Apocalypse/Outbreak/Extinction/Rising",
      "scan": "*.lua",
      "context": "Game modes renamed in 42.15"
    }
  ]
}
