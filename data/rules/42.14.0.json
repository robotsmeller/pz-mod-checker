{
  "version": "42.14.0",
  "summary": "Ammunition rework, fluid container removals, item removals",
  "source": "https://pzwiki.net/wiki/Build_42.14.0",
  "release_date": "2026-02-16",
  "changes": [
    {
      "id": "b42-14-223-ammo-removed",
      "type": "api_removal",
      "severity": "breaking",
      "confidence": "certain",
      "since": "42.14.0",
      "description": ".223 ammunition items removed from game — use 5.56 instead",
      "pattern": "\\bBullets223\\b|\\b223Rounds\\b|\\.223\\b",
      "regex": true,
      "scan": "*.lua",
      "context": ".223 ammo removed in 42.14, replaced with 5.56",
      "group": "ammo-rework"
    },
    {
      "id": "b42-14-223-script",
      "type": "api_removal",
      "severity": "breaking",
      "confidence": "certain",
      "since": "42.14.0",
      "description": ".223 ammunition references in scripts — use 5.56",
      "pattern": "\\.223\\b|\\bBullets223\\b|\\b223Rounds\\b|\\b223Box\\b",
      "regex": true,
      "scan": "*.txt",
      "path": "media/scripts/",
      "context": ".223 ammo removed in 42.14",
      "group": "ammo-rework"
    },
    {
      "id": "b42-14-revolver-ammo-changed",
      "type": "api_rename",
      "severity": "warning",
      "confidence": "likely",
      "since": "42.14.0",
      "description": "Base.Revolver changed from .45 ACP to .357 Magnum — mods hardcoding revolver ammo may be affected",
      "old_pattern": "\\bBullets45\\b",
      "regex": true,
      "new_name": ".357 Magnum rounds",
      "scan": "*.lua",
      "context": "Only affects mods that hardcode revolver ammo; .45 ACP (Bullets45) is still in game for other weapons",
      "group": "ammo-rework"
    },
    {
      "id": "b42-14-bakingtray-fluid-removed",
      "type": "api_removal",
      "severity": "info",
      "confidence": "certain",
      "since": "42.14.0",
      "description": "Fluid container properties removed from BakingTray, BakingPan, RoastingPan",
      "pattern": "BakingTray|BakingPan|RoastingPan",
      "regex": true,
      "scan": "*.lua",
      "context": "These items no longer function as fluid containers in 42.14"
    },
    {
      "id": "b42-14-crushed-limestone-lua",
      "type": "api_removal",
      "severity": "breaking",
      "confidence": "certain",
      "since": "42.14.0",
      "description": "Crushed Limestone/ore items removed — recipes use raw materials directly",
      "pattern": "CrushedLimestone|CrushedCopperOre|CrushedIronOre",
      "regex": true,
      "scan": "*.lua",
      "context": "Items removed in 42.14",
      "group": "crushed-ore-removal"
    },
    {
      "id": "b42-14-glazing-removed",
      "type": "api_removal",
      "severity": "warning",
      "confidence": "certain",
      "since": "42.14.0",
      "description": "Glazing pottery recipes and items removed",
      "pattern": "Glazing|GlazedPottery|PotteryGlaze",
      "regex": true,
      "scan": "*.lua",
      "context": "Glazing system removed in 42.14"
    },
    {
      "id": "b42-14-alcohol-renamed",
      "type": "api_rename",
      "severity": "info",
      "confidence": "certain",
      "since": "42.14.0",
      "description": "Disinfectant type renamed from Alcohol to Rubbing Alcohol",
      "old_pattern": "\\\"Alcohol\\\"",
      "new_name": "\\\"Rubbing Alcohol\\\"",
      "scan": "*.txt",
      "path": "media/scripts/",
      "context": "Item type renamed in 42.14"
    }
  ]
}
